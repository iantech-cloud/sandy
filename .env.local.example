# ============================================================================
# ENVIRONMENT CONFIGURATION - Replace placeholders with actual values
# ============================================================================

# Authentication & Security
NEXTAUTH_SECRET=your_actual_nextauth_secret_key_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email Service
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM_NAME=Your App Name
EMAIL_FROM_ADDRESS=noreply@example.com

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Security
ANTI_PHISHING_ENCRYPTION_KEY=your_encryption_key_here

# ============================================================================
# M-PESA DARAJA CONFIGURATION (STK Push)
# Get these from: https://developer.safaricom.co.ke/
# ============================================================================
MPESA_CONSUMER_KEY=your_daraja_consumer_key_here
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret_here
MPESA_SHORT_CODE=4182501
MPESA_PASS_KEY=your_daraja_passkey_here
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=development
PORT=3000
HOSTNAME=localhost

# URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000

# Account
ACCOUNT_ID=your_account_id_here

# ============================================================================
# Third-Party APIs
# ============================================================================
NVIDIA_API_KEY=your_nvidia_api_key_here
CRON_SECRET=your_cron_secret_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# NOTES:
# - Never commit .env.local to version control
# - All values marked "your_*_here" MUST be replaced with actual credentials
# - For development, use Daraja sandbox credentials
# - For production, use Daraja production credentials and set MPESA_ENVIRONMENT=production
# ============================================================================
