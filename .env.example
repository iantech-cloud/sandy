# ============================================
# AUTHENTICATION & SESSION
# ============================================
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://hustlehubafrica.com

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_NAME=HustleHub Africa
EMAIL_FROM_ADDRESS=noreply@hustlehubafrica.com

# ============================================
# DATABASE (MONGODB)
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hustlehubafrica

# ============================================
# ENCRYPTION
# ============================================
ANTI_PHISHING_ENCRYPTION_KEY=your-32-character-hex-encryption-key

# ============================================
# MPESA PAYMENT GATEWAY (Safaricom Legacy)
# ============================================
MPESA_SHORTCODE=your-mpesa-shortcode
MPESA_PASSKEY=your-mpesa-passkey
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_CALLBACK_URL=https://hustlehubafrica.com/api/mpesa/callback
MPESA_ENVIRONMENT=production

# ============================================
# CO-OPERATIVE BANK M-PESA (PRIMARY PAYMENT)
# ⚠️  IMPORTANT: Use exact variable names below
# ============================================
# These MUST be named exactly as shown - not COOP_BANK_*
COOP_CLIENT_ID=your-coop-bank-client-id
COOP_CLIENT_SECRET=your-coop-bank-client-secret
COOP_OPERATOR_CODE=your-operator-code
# Optional: Override API endpoints (defaults to production)
COOP_BASE_URL=https://openapi.co-opbank.co.ke
COOP_TOKEN_URL=https://openapi.co-opbank.co.ke/token
COOP_STK_PUSH_URL=https://openapi.co-opbank.co.ke/FT/stk/1.0.0
COOP_STK_STATUS_URL=https://openapi.co-opbank.co.ke/Enquiry/STK/1.0.0/

# ============================================
# PUBLIC URLS & BASE URLs
# ============================================
NEXT_PUBLIC_BASE_URL=https://hustlehubafrica.com
API_BASE_URL=https://hustlehubafrica.com

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=5000
HOSTNAME=0.0.0.0
