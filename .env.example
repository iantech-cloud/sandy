# ============================================
# AUTHENTICATION & SESSION
# ============================================
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://hustlehubafrica.com

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_NAME=HustleHub Africa
EMAIL_FROM_ADDRESS=noreply@hustlehubafrica.com

# ============================================
# DATABASE (MONGODB)
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hustlehubafrica

# ============================================
# ENCRYPTION
# ============================================
ANTI_PHISHING_ENCRYPTION_KEY=your-32-character-hex-encryption-key

# ============================================
# MPESA DARAJA - PRIMARY PAYMENT GATEWAY
# Safaricom M-PESA API for all payments
# ============================================
# Get from: https://developer.safaricom.co.ke/
# 1. Create Daraja account
# 2. Create sandbox app to get Consumer Key & Secret
# 3. Create M-PESA test app for pass key

# OAuth Credentials - Required for all API calls
DARAJA_CONSUMER_KEY=your-daraja-consumer-key
DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret

# STK Push Configuration
DARAJA_BUSINESS_SHORT_CODE=600123
DARAJA_PASSKEY=your-daraja-passkey

# API Configuration
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_OAUTH_URL=https://sandbox.safaricom.co.ke/oauth/v1/generate
DARAJA_STK_PUSH_URL=https://sandbox.safaricom.co.ke/mpesa/stkpush/v1/processrequest
DARAJA_STATUS_CHECK_URL=https://sandbox.safaricom.co.ke/mpesa/stkpushquery/v1/query

# Callback URL Registration - IMPORTANT!
# This URL is where M-PESA sends transaction callbacks
# Must be publicly accessible (use ngrok for local testing)
# Example: https://your-domain.com/api/payments/daraja/callback
DARAJA_CALLBACK_URL=https://hustlehubafrica.com/api/payments/daraja/callback
DARAJA_C2B_VALIDATION_URL=https://hustlehubafrica.com/api/payments/daraja/c2b/validate
DARAJA_C2B_CONFIRMATION_URL=https://hustlehubafrica.com/api/payments/daraja/c2b/confirm
DARAJA_B2C_RESULT_URL=https://hustlehubafrica.com/api/payments/daraja/callback
DARAJA_B2B_RESULT_URL=https://hustlehubafrica.com/api/payments/daraja/callback
DARAJA_BALANCE_RESULT_URL=https://hustlehubafrica.com/api/payments/daraja/callback
DARAJA_REVERSAL_RESULT_URL=https://hustlehubafrica.com/api/payments/daraja/callback

# Security Credentials for B2C/B2B/Reversal (optional - for payout features)
# Only needed if implementing business payouts (B2C) or B2B transfers
# These are NOT used for STK Push (customer payments)
# Leave empty if you only need STK Push for now
# Format: Read from Daraja portal after generating credentials
MPESA_PUBLIC_KEY_SANDBOX=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
MPESA_PUBLIC_KEY_PRODUCTION=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...

# ============================================
# LEGACY: CO-OPERATIVE BANK (DEPRECATED)
# ⚠️  Replaced by M-PESA Daraja integration
# Keep for reference only - no longer used
# ============================================
# COOP_BANK_BASIC_AUTH=Basic ...
# COOP_BANK_OPERATOR_CODE=SANDRA

# ============================================
# PUBLIC URLS & BASE URLs
# ============================================
NEXT_PUBLIC_BASE_URL=https://hustlehubafrica.com
API_BASE_URL=https://hustlehubafrica.com

# ============================================
# REFERRAL TRACKING
# ============================================
# Default referral code for users without a referral link
DEFAULT_REFERRAL_ID=SANDY001

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=5000
HOSTNAME=0.0.0.0
