# ============================================
# AUTHENTICATION & SESSION
# ============================================
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://hustlehubafrica.com

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_NAME=HustleHub Africa
EMAIL_FROM_ADDRESS=noreply@hustlehubafrica.com

# ============================================
# DATABASE (MONGODB)
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hustlehubafrica

# ============================================
# ENCRYPTION
# ============================================
ANTI_PHISHING_ENCRYPTION_KEY=your-32-character-hex-encryption-key

# ============================================
# MPESA PAYMENT GATEWAY (Safaricom Legacy)
# ============================================
MPESA_SHORTCODE=your-mpesa-shortcode
MPESA_PASSKEY=your-mpesa-passkey
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_CALLBACK_URL=https://hustlehubafrica.com/api/mpesa/callback
MPESA_ENVIRONMENT=production

# ============================================
# HASHBACK PAYMENT (PRIMARY PAYMENT)
# ⚠️  REQUIRED: API Key and Account ID
# ============================================
# Get from: https://hashback.co.ke/ → Settings
HASHBACK_API_KEY=your-hashback-api-key
HASHBACK_ACCOUNT_ID=your-hashback-account-id
HASHBACK_WEBHOOK_SECRET=your-hashback-webhook-secret

# ============================================
# CO-OPERATIVE BANK M-PESA (FALLBACK PAYMENT)
# ⚠️  OPTIONAL: Used only if HashBack fails
# ============================================
# COOP_BANK_BASIC_AUTH: Pre-encoded authorization header "Basic <base64...>"
# Extract from Postman collection → Token request → Authorization header
COOP_BANK_BASIC_AUTH=Basic MktETXRDZnpfSHZscUYzaFNBemxjUmQxTFdVYTpVVkM3ZGM0NDhKZWxtZXBIb3ZuZnpWMFZBbGNh
COOP_BANK_OPERATOR_CODE=SANDRA
# Optional: Override API endpoints (defaults to production Co-op Bank URLs)
COOP_BANK_BASE_URL=https://openapi.co-opbank.co.ke
COOP_BANK_TOKEN_ENDPOINT=/token
COOP_BANK_STK_PUSH_ENDPOINT=/FT/stk/1.0.0
COOP_BANK_STK_STATUS_ENDPOINT=/Enquiry/STK/1.0.0/

# ============================================
# PUBLIC URLS & BASE URLs
# ============================================
NEXT_PUBLIC_BASE_URL=https://hustlehubafrica.com
API_BASE_URL=https://hustlehubafrica.com

# ============================================
# REFERRAL TRACKING
# ============================================
# Default referral code for users without a referral link
DEFAULT_REFERRAL_ID=SANDY001

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=5000
HOSTNAME=0.0.0.0
